#!/usr/bin/env bash
# 0-change_your_home_IP - /etc/hosts faylını dəyişdirir (sed -i olmadan)

TMP_FILE=$(mktemp)
sudo grep -vE '^(127\.0\.0\.1\s+.*localhost|::1\s+.*localhost|.*facebook\.com)' /etc/hosts > "$TMP_FILE"
echo "127.0.0.2 localhost" | sudo tee -a "$TMP_FILE" > /dev/null
echo "8.8.8.8 facebook.com" | sudo tee -a "$TMP_FILE" > /dev/null
sudo tee /etc/hosts < "$TMP_FILE" > /dev/null
rm "$TMP_FILE"
